<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<title>林氏誤差憲法・脈衝光梯模擬（八索引孩子 + 三觀測者）</title>
<style>
  body { margin:0; background:#000; font-family:monospace; color:#0ff; overflow:hidden; }
  canvas { display:block; }
  #ui {
    position:absolute; top:10px; left:10px; background:rgba(0,20,40,0.9); padding:12px; border:1px solid #0ff; border-radius:8px; width:260px;
    box-shadow:0 0 15px #0ff;
  }
  button, input { margin:4px 0; padding:6px 10px; background:#001122; color:#0ff; border:1px solid #0ff; font-family:monospace; }
  .phase { font-size:14px; color:#ff0; }
</style>
</head>
<body>
<canvas id="c" width="1200" height="800"></canvas>
<div id="ui">
  <div class="phase" id="phase">階段 1 / 6：混沌箭頭誕生</div>
  <button onclick="togglePause()">▶ 暫停 / 繼續</button>
  <button onclick="nextPhase()">下一階段</button><br>
  <label>插值密度 <input type="range" id="density" min="1" max="8" value="3" oninput="density=this.value"></label><br>
  <label>脈衝頻率 <input type="range" id="pulseFreq" min="1" max="20" value="8" oninput="pulseFreq=this.value"></label><br>
  <button onclick="switchObserver(1)">第一觀測者</button>
  <button onclick="switchObserver(2)">第二觀測者（插值變換）</button>
  <button onclick="switchObserver(3)">第三觀測者（脈衝迭代）</button>
  <div style="margin-top:8px;font-size:12px;color:#0a0;">球星數：<span id="starCount">128</span>　法線方向：<span id="normalDir">統一向外</span></div>
</div>

<script>
// ================ 林氏脈衝光梯模擬 ================
const canvas = document.getElementById('c');
const ctx = canvas.getContext('2d');
let W = canvas.width, H = canvas.height;
let time = 0, paused = false;
let phase = 1; // 1~6
let observer = 1; // 1,2,3
let interpDensity = 3;
let pulseFrequency = 8;
let pulsePhase = 0;

// 球星 = 粒子群（位置、速度、半徑、顏色）
let stars = [];
function createStar(x,y,r,color) {
  return {x, y, vx:0, vy:0, r, color, clusterId: Math.random()};
}

// 初始化128個球星
function initStars() {
  stars = [];
  for(let i=0; i<128; i++){
    stars.push(createStar(
      W/2 + (Math.random()-0.5)*400,
      H/2 + (Math.random()-0.5)*400,
      3 + Math.random()*4,
      `hsl(${Math.random()*360},100%,70%)`
    ));
  }
}
initStars();

// 八索引孩子方向箭頭（背景）
const eightDirections = [
  {dx:1, dy:0, label:"∞大"}, {dx:-1, dy:0, label:"∞小"},
  {dx:0, dy:1, label:"≈∞大"}, {dx:0, dy:-1, label:"≈∞小"},
  {dx:0.707, dy:0.707, label:"斷裂"}, {dx:-0.707, dy:-0.707, label:"≈斷"},
  {dx:0.707, dy:-0.707, label:"連續"}, {dx:-0.707, dy:0.707, label:"≈連"}
];

function drawBackground() {
  ctx.fillStyle = '#000511';
  ctx.fillRect(0,0,W,H);
  
  // 八索引孩子
  ctx.strokeStyle = 'rgba(0,255,255,0.15)';
  ctx.lineWidth = 1;
  for(let i=0; i<8; i++){
    let d = eightDirections[i];
    let len = 180;
    ctx.beginPath();
    ctx.moveTo(W/2, H/2);
    ctx.lineTo(W/2 + d.dx*len, H/2 + d.dy*len);
    ctx.stroke();
    ctx.fillStyle = '#0ff';
    ctx.font = '10px monospace';
    ctx.fillText(d.label, W/2 + d.dx*len*1.1, H/2 + d.dy*len*1.1);
  }
  
  // 中心奇點
  ctx.shadowBlur = 30;
  ctx.shadowColor = '#f0f';
  ctx.fillStyle = phase >= 5 ? '#f0f' : '#222';
  ctx.beginPath();
  ctx.arc(W/2, H/2, phase >= 5 ? 12 : 8, 0, Math.PI*2);
  ctx.fill();
  ctx.shadowBlur = 0;
}

// 向心/離心力
function applyCentripetal() {
  const cx = W/2, cy = H/2;
  for(let s of stars){
    let dx = cx - s.x, dy = cy - s.y;
    let dist = Math.hypot(dx,dy) || 1;
    let force = phase <= 3 ? 0.008 : (phase === 4 ? -0.012 : 0.018); // 向心→離心→再向心
    s.vx += dx/dist * force;
    s.vy += dy/dist * force;
  }
}

// 螺旋 + 密集插值（時間插值尺寸變小）
function applySpiralDense() {
  const cx = W/2, cy = H/2;
  let densityFactor = Math.max(0.3, 3 - interpDensity*0.3); // 越小越密集
  for(let s of stars){
    let dx = s.x - cx, dy = s.y - cy;
    let r = Math.hypot(dx,dy) || 1;
    let theta = Math.atan2(dy,dx);
    // 角速度 + 徑向收縮
    let omega = 0.015 / (r/300 + 0.5);
    theta += omega * densityFactor;
    let newR = r * (0.995 - interpDensity*0.002); // 插值尺寸持續變小
    s.x = cx + Math.cos(theta) * newR;
    s.y = cy + Math.sin(theta) * newR;
    // 輕微亂流（混沌箭頭）
    if(phase === 1) {
      s.vx += (Math.random()-0.5)*0.8;
      s.vy += (Math.random()-0.5)*0.8;
    }
  }
}

// 異性方向收斂 → 統一方向通脹
function convergeToUnified() {
  const cx = W/2, cy = H/2;
  let unifiedAngle = (time * 0.003) % (Math.PI*2); // 統一法線隨時間旋轉
  for(let s of stars){
    let dx = s.x - cx, dy = s.y - cy;
    let r = Math.hypot(dx,dy) || 1;
    let targetAngle = unifiedAngle;
    s.x = cx + Math.cos(targetAngle) * r * 1.008; // 輕微通脹
    s.y = cy + Math.sin(targetAngle) * r * 1.008;
  }
}

// 第三觀測者脈衝
function drawPulse() {
  pulsePhase += 0.12 * pulseFrequency;
  const cx = W/2, cy = H/2;
  let radius = (pulsePhase % 120) * 6; // 向外擴張
  
  // 光梯色譜（彩虹漸層）
  let grad = ctx.createRadialGradient(cx, cy, 10, cx, cy, radius+80);
  for(let i=0; i<=1; i+=0.1){
    let hue = (pulsePhase*8 + i*360) % 360;
    grad.addColorStop(i, `hsla(${hue},100%,80%,${1-i*0.9})`);
  }
  ctx.shadowBlur = 60;
  ctx.shadowColor = '#ff0';
  ctx.strokeStyle = grad;
  ctx.lineWidth = 18;
  ctx.beginPath();
  ctx.arc(cx, cy, radius, 0, Math.PI*2);
  ctx.stroke();
  ctx.shadowBlur = 0;
  
  // 唯一法線箭頭（方向異性收斂後的統一方向）
  let arrowAngle = (pulsePhase * 0.8) % (Math.PI*2);
  ctx.strokeStyle = '#ff0';
  ctx.lineWidth = 4;
  ctx.beginPath();
  ctx.moveTo(cx, cy);
  ctx.lineTo(cx + Math.cos(arrowAngle)*220, cy + Math.sin(arrowAngle)*220);
  ctx.stroke();
  
  // 箭頭頭
  ctx.fillStyle = '#ff0';
  ctx.beginPath();
  ctx.moveTo(cx + Math.cos(arrowAngle)*220, cy + Math.sin(arrowAngle)*220);
  ctx.lineTo(cx + Math.cos(arrowAngle+0.3)*190, cy + Math.sin(arrowAngle+0.3)*190);
  ctx.lineTo(cx + Math.cos(arrowAngle-0.3)*190, cy + Math.sin(arrowAngle-0.3)*190);
  ctx.fill();
}

// 第二觀測者插值變換（畫面扭曲）
function applyObserver2Transform() {
  if(observer !== 2) return;
  ctx.save();
  ctx.translate(W/2, H/2);
  ctx.rotate(Math.sin(time*0.01)*0.04); // 輕微旋轉插值
  ctx.scale(1 + Math.sin(time*0.008)*0.08, 1 + Math.cos(time*0.008)*0.08);
  ctx.translate(-W/2, -H/2);
}

function update() {
  if(paused) return;
  time += 0.016;
  
  drawBackground();
  
  // 階段切換
  if(phase === 1) { // 混沌箭頭
    document.getElementById('phase').innerHTML = `階段 1/6：時間標籤有限插值 → 混沌箭頭`;
    applyCentripetal();
    for(let s of stars){ s.x += s.vx; s.y += s.vy; s.vx*=0.96; s.vy*=0.96; }
  }
  else if(phase === 2) { // 向心成球星
    document.getElementById('phase').innerHTML = `階段 2/6：向心凝聚 → 球星形成`;
    applyCentripetal();
  }
  else if(phase === 3) { // 球星系離心
    document.getElementById('phase').innerHTML = `階段 3/6：球星系離心`;
    applyCentripetal(); // 力改為負
    for(let s of stars){ s.vx += (Math.random()-0.5)*0.6; s.vy += (Math.random()-0.5)*0.6; }
  }
  else if(phase === 4) { // 向心螺旋 + 密集插值
    document.getElementById('phase').innerHTML = `階段 4/6：向心螺旋 + 密集時間插值`;
    applySpiralDense();
  }
  else if(phase === 5) { // 方向異性收斂 → 統一通脹
    document.getElementById('phase').innerHTML = `階段 5/6：方向異性收斂 → 統一方向通脹`;
    convergeToUnified();
  }
  else if(phase === 6) { // 第三觀測者脈衝
    document.getElementById('phase').innerHTML = `階段 6/6：奇點脈衝迭代（第三觀測者）`;
    convergeToUnified();
    drawPulse();
  }
  
  // 繪製球星
  applyObserver2Transform(); // 第二觀測者變換只在需要時套用
  for(let s of stars){
    ctx.shadowBlur = 15;
    ctx.shadowColor = s.color;
    ctx.fillStyle = s.color;
    ctx.beginPath();
    ctx.arc(s.x, s.y, s.r, 0, Math.PI*2);
    ctx.fill();
    ctx.shadowBlur = 0;
  }
  
  // 第二觀測者結束變換
  if(observer === 2) ctx.restore();
  
  // 粒子數顯示
  document.getElementById('starCount').textContent = stars.length;
  document.getElementById('normalDir').innerHTML = phase >= 5 ? '✅ 單一法線' : '異性方向';
  
  requestAnimationFrame(update);
}

// 控制函數
function togglePause(){ paused = !paused; }
function nextPhase(){ phase = Math.min(phase+1, 6); if(phase===6) pulsePhase=0; }
function switchObserver(n){ observer = n; }

document.getElementById('density').oninput = function(){ interpDensity = +this.value; };
document.getElementById('pulseFreq').oninput = function(){ pulseFrequency = +this.value; };

// 啟動
update();
</script>
</body>
</html>
